// PUSPA V4 — Pertubuhan Urus Peduli Asnaf NGO Management Platform
// Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ───────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("staff") // staff, admin, developer
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities    Activity[]
  caseNotes     CaseNote[]
  aiConversations AiConversation[]
}

// ─── Asnaf Members ──────────────────────────────────────────────

model Member {
  id              String   @id @default(cuid())
  icNumber        String   @unique
  name            String
  phone           String?
  email           String?
  address         String?
  city            String?
  state           String?
  postcode        String?
  gender          String?  // male, female
  dateOfBirth     String?
  occupation      String?
  monthlyIncome   Float    @default(0)
  householdSize   Int      @default(1)
  asnafCategory   String   @default("fakir") // fakir, miskin, amil, gharim, riqab, gharim, ibn sabil, muallaf
  status          String   @default("active") // active, inactive, pending
  ekycStatus      String   @default("pending") // pending, verified, rejected
  ekycRiskLevel   String?  // low, medium, high
  ekycVerifiedBy  String?
  ekycVerifiedAt  DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  householdMembers HouseholdMember[]
  cases          Case[]
  disbursements  Disbursement[]
  programmeEnrolments ProgrammeBeneficiary[]
  documents      Document[]
  ekycRecords    EKYCVerification[]
}

model HouseholdMember {
  id          String   @id @default(cuid())
  memberId    String
  name        String
  relationship String // spouse, child, parent, sibling, other
  icNumber    String?
  dateOfBirth String?
  occupation  String?
  monthlyIncome Float  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// ─── Cases ──────────────────────────────────────────────────────

model Case {
  id            String   @id @default(cuid())
  caseNumber    String   @unique
  memberId      String
  type          String   // welfare, medical, education, housing, emergency, financial
  priority      String   @default("medium") // low, medium, high, urgent
  status        String   @default("draft") // draft, intake, verification, assessment, approval, disbursement, follow_up, closed, rejected
  description   String?
  requestedAmount Float?
  approvedAmount   Float?
  riskIndicator    String? // low, medium, high, critical
  welfareScore     Float?
  nextAction    String?
  nextActionDate String?
  assignedTo    String?
  closedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  member        Member     @relation(fields: [memberId], references: [id])
  notes         CaseNote[]
  disbursements Disbursement[]
  documents     Document[]
  programmes    CaseProgramme[]
}

model CaseNote {
  id        String   @id @default(cuid())
  caseId    String
  authorId  String
  type      String   @default("note") // note, action, decision, follow_up
  content   String
  createdAt DateTime @default(now())

  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
}

model CaseProgramme {
  id          String @id @default(cuid())
  caseId      String
  programmeId String

  case        Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  programme   Programme @relation(fields: [programmeId], references: [id])
}

// ─── Donations & Donors ─────────────────────────────────────────

model Donor {
  id              String    @id @default(cuid())
  donorNumber     String    @unique
  name            String
  ic              String?
  email           String?
  phone           String?
  address         String?
  type            String     @default("individual") // individual, corporate, government
  category        String?    // regular, occasional, one_time
  isAnonymous     Boolean    @default(false)
  preferredContact String?   // email, phone, null
  status          String     @default("active") // active, inactive, blacklisted
  totalDonated    Float      @default(0)
  donationCount   Int        @default(0)
  firstDonationAt DateTime?
  lastDonationAt  DateTime?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  donations   Donation[]
}

model Donation {
  id               String   @id @default(cuid())
  donorId          String?
  donorName        String?
  donorIC          String?
  donorEmail       String?
  donorPhone       String?
  isAnonymous      Boolean  @default(false)
  category         String   @default("sadaqah") // zakat, sadaqah, waqf, infaq, general
  amount           Float
  currency         String   @default("MYR")
  method           String?  // cash, bank_transfer, online, cheque
  status           String   @default("confirmed") // pending, confirmed, cancelled, refunded
  receiptNumber    String?
  receiptIssued    Boolean  @default(false)
  shariahCompliant Boolean  @default(true)
  date             String?
  donatedAt        DateTime @default(now())
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  donor            Donor?   @relation(fields: [donorId], references: [id])
}

// ─── Disbursements ──────────────────────────────────────────────

model Disbursement {
  id              String   @id @default(cuid())
  memberId        String
  caseId          String?
  programmeId     String?
  amount          Float
  category        String   // welfare, medical, education, housing, emergency, monthly_aid
  status          String   @default("pending") // pending, approved, disbursed, verified, cancelled
  paymentMethod   String?  // cash, bank_transfer, cheque
  paymentRef      String?
  scheduledDate   String?
  disbursedDate   String?
  verifiedBy      String?
  verifiedAt      DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  member          Member      @relation(fields: [memberId], references: [id])
  case            Case?       @relation(fields: [caseId], references: [id])
  programme       Programme?  @relation(fields: [programmeId], references: [id])
}

// ─── Programmes ─────────────────────────────────────────────────

model Programme {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   // education, welfare, health, economic, social, religious
  status      String   @default("planning") // planning, active, completed, suspended
  budget      Float    @default(0)
  spent       Float    @default(0)
  startDate   String?
  endDate     String?
  location    String?
  targetBeneficiaries Int @default(0)
  impactMetric String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  beneficiaries ProgrammeBeneficiary[]
  disbursements Disbursement[]
  cases         CaseProgramme[]
  documents     Document[]
  activities    Activity[]
}

model ProgrammeBeneficiary {
  id          String   @id @default(cuid())
  programmeId String
  memberId    String
  status      String   @default("enrolled") // enrolled, active, completed, withdrawn
  enrolledAt  DateTime @default(now())

  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  member      Member    @relation(fields: [memberId], references: [id])
}

// ─── Volunteers ─────────────────────────────────────────────────

model Volunteer {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  skills      String?  // comma-separated
  availability String? // weekdays, weekends, flexible
  status      String   @default("active") // active, inactive, suspended
  totalHours  Float    @default(0)
  joinedAt    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activities  VolunteerActivity[]
  certificates VolunteerCertificate[]
}

model VolunteerActivity {
  id            String   @id @default(cuid())
  volunteerId   String
  activityId    String?
  programmeId   String?
  hours         Float    @default(0)
  role          String?
  status        String   @default("logged") // logged, approved, rejected
  date          String?
  notes         String?
  createdAt     DateTime @default(now())

  volunteer     Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
}

model VolunteerCertificate {
  id            String   @id @default(cuid())
  volunteerId   String
  title         String
  issuedDate    String?
  certificateUrl String?
  createdAt     DateTime @default(now())

  volunteer     Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
}

// ─── Compliance ─────────────────────────────────────────────────

model ComplianceRecord {
  id          String   @id @default(cuid())
  category    String   // rosm, lhdn, pdpa, internal, audit
  title       String
  description String?
  status      String   @default("pending") // pending, compliant, non_compliant, expired, under_review
  dueDate     String?
  completedAt String?
  evidenceUrl String?
  notes       String?
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── eKYC ───────────────────────────────────────────────────────

model EKYCVerification {
  id            String   @id @default(cuid())
  memberId      String
  icFrontUrl    String?
  icBackUrl     String?
  selfieUrl     String?
  ocrExtracted  String?  // JSON string of OCR data
  faceMatchScore Float?
  riskLevel     String   @default("pending") // pending, low, medium, high
  status        String   @default("pending") // pending, submitted, under_review, verified, rejected
  verifiedBy    String?
  verifiedAt    DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  member        Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// ─── Documents ──────────────────────────────────────────────────

model Document {
  id          String   @id @default(cuid())
  title       String
  category    String   // member, case, programme, compliance, general
  fileName    String?
  fileUrl     String?
  fileSize    Int?
  mimeType    String?
  version     Int      @default(1)
  memberId    String?
  caseId      String?
  programmeId String?
  uploadedBy  String?
  tags        String?  // comma-separated
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  member      Member?    @relation(fields: [memberId], references: [id])
  case        Case?      @relation(fields: [caseId], references: [id])
  programme   Programme? @relation(fields: [programmeId], references: [id])
}

// ─── Activities / Audit ─────────────────────────────────────────

model Activity {
  id          String   @id @default(cuid())
  userId      String?
  type        String   // member_created, case_updated, donation_received, etc.
  category    String   // member, case, donation, disbursement, programme, volunteer, compliance, system
  title       String
  description String?
  entityType  String?  // Member, Case, Donation, etc.
  entityId    String?
  metadata    String?  // JSON string
  programmeId String?
  createdAt   DateTime @default(now())

  user        User?      @relation(fields: [userId], references: [id])
  programme   Programme? @relation(fields: [programmeId], references: [id])
}

// ─── AI / Hermes ────────────────────────────────────────────────

model AIMemory {
  id        String   @id @default(uuid())
  userId    String
  role      String   // user, assistant, system, tool
  content   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model AiConversation {
  id          String   @id @default(cuid())
  userId      String
  title       String?
  model       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User             @relation(fields: [userId], references: [id])
  messages    AiMessage[]
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user, assistant, system, tool
  content        String
  toolCalls      String?  // JSON string
  toolResults    String?  // JSON string
  model          String?
  tokens         Int?
  createdAt      DateTime @default(now())

  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// ─── Ops / Developer ────────────────────────────────────────────

model OpsWorkItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   // task, bug, improvement, automation
  status      String   @default("pending") // pending, approved, rejected, revised, in_progress, completed
  priority    String   @default("medium")
  requestedBy String?
  approvedBy  String?
  executionTrace String? // JSON string
  result      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AutomationJob {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // scheduled, event_triggered, manual
  schedule    String?  // cron expression or event name
  config      String?  // JSON string
  status      String   @default("inactive") // active, inactive, paused, error
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
